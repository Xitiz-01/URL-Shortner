<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title> URL Shortener</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: linear-gradient(135deg, #f0f4ff, #e0e7ff);
      min-height: 100vh;
      padding: 60px 20px;
      color: #1e293b;
    }

    .container {
      max-width: 950px;
      margin: auto;
    }

    h1 {
      text-align: center;
      font-size: 38px;
      font-weight: 700;
      margin-bottom: 50px;
      background: linear-gradient(90deg, #6366f1, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .card {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 35px;
      margin-bottom: 35px;
      box-shadow: 0 20px 50px rgba(99, 102, 241, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.4);
      transition: 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 25px 60px rgba(99, 102, 241, 0.25);
    }

    form {
      display: flex;
      gap: 15px;
    }

    input {
      flex: 1;
      padding: 16px;
      border-radius: 12px;
      border: 1px solid #dbeafe;
      font-size: 15px;
      transition: 0.3s ease;
    }

    input:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
      outline: none;
    }

    button {
      padding: 16px 28px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(90deg, #6366f1, #8b5cf6);
      color: white;
      font-weight: 600;
      font-size: 15px;
      cursor: pointer;
      transition: 0.3s ease;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
    }

    .generated {
      margin-top: 25px;
      padding: 18px;
      border-radius: 14px;
      background: rgba(99, 102, 241, 0.08);
      font-size: 15px;
    }

    .generated a {
      font-weight: 600;
      color: #6366f1;
      text-decoration: none;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th {
      text-align: left;
      padding-bottom: 14px;
      font-size: 14px;
      color: #64748b;
      font-weight: 600;
    }

    td {
      padding: 18px 0;
      border-top: 1px solid rgba(0, 0, 0, 0.05);
      font-size: 15px;
    }

    tr:hover {
      background: rgba(99, 102, 241, 0.05);
      border-radius: 10px;
    }

    .short-link a {
      font-weight: 600;
      color: #8b5cf6;
      text-decoration: none;
    }

    .clicks {
      font-weight: 600;
      color: #6366f1;
    }

    @media (max-width: 700px) {
      form {
        flex-direction: column;
      }

      button {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <h1> URL Shortener</h1>

    <div class="card">
      <form method="POST" action="/url">
        <input
          type="text"
          name="url"
          placeholder="Paste your long URL here..."
          required
        />
        <button type="submit">Generate</button>
      </form>

      <% if (locals.id) { %>
      <div class="generated">
        🔗 Your Short Link:
        <a href="/url/<%= id %>" target="_blank">
          http://localhost:8001/url/<%= id %>
        </a>
      </div>
      <% } %>
    </div>

    <% if (locals.urls && urls.length > 0) { %>
    <div class="card">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Short Link</th>
            <th>Original URL</th>
            <th>Clicks</th>
          </tr>
        </thead>
        <tbody>
          <% urls.forEach((url, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td class="short-link">
              <a href="/url/<%= url.shortId %>" target="_blank">
                <%= url.shortId %>
              </a>
            </td>
            <td style="word-break: break-word;">
              <%= url.redirectURL %>
            </td>
            <td class="clicks">
              <%= url.visitHistory.length %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</body>
</html>